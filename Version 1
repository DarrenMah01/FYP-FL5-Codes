#include <FlexCAN_T4.h>
#include <SD.h>
#include <math.h>
#include <stdio.h>

// Datalogging 
File logFile;
const int chipSelect = BUILTIN_SDCARD;

elapsedMicros logTimer;
elapsedMillis serialTimer;
const int logInterval = 5000; // log every 5ms (200Hz)

// Read PWM Variavles
volatile uint32_t riseTime = 0;
volatile uint32_t width = 0;
volatile uint32_t period = 0;
volatile uint32_t lastEdgeTime = 0;

// Define your ADC pins
const int adcPins[] = {A9,A8,A7,A6,A5,A4,A3,A2,A1,A0,A17};
const int numChannels = sizeof(adcPins) / sizeof(adcPins[0]);
int adcValues[numChannels];
const int samplingRate = 1000; //in microsecond = 1kHz
IntervalTimer myTimer;

// Define PWM Outputs
const int pwmPins[] = {2,3,4,5};
const int pwmFreq = 1000;

// Define CAN setups
FlexCAN_T4<CAN3, RX_SIZE_256, TX_SIZE_16> Can0; // using CAN Controller No.3 
const int CANBaud = 500000; //CAN Speed

// Interrupt routine for ADC reading
void AdcISR() {
  for (int i = 0; i < numChannels; i++){
    adcValues[i] = analogRead(adcPins[i]);
  }
}

// read pwm 
void pwmISR() {
  uint32_t now = micros();
  lastEdgeTime = now;

  if (digitalRead(40)) {   // RISING edge
    period = now - riseTime;
    riseTime = now;
  } else {                 // FALLING edge
    width = now - riseTime;
  }
}

// Convert ADC value into 0 - 5V value
float Convert2Volt(int inVal) {
  return ((float(inVal) * 5) /1023);
}

// Setup PWM pins 
void SetupPWM(){
  for (int i = 0; i < (sizeof(pwmPins)/sizeof(pwmPins[0])); i++){
    pinMode(pwmPins[i], OUTPUT); // set output pins
    analogWriteFrequency(pwmPins[i], pwmFreq);
  }
  analogWriteResolution(8);         // 8-bit resolution (0–255)
}

// Setup CAN Bus
void InitCan(){
  Can0.begin();
  Can0.setBaudRate(CANBaud);
  Can0.enableFIFO();
  Can0.enableFIFOInterrupt();
  Can0.onReceive(ReadFrame);
}
// CAN variables
volatile int mode = 0; //1 = comfort, 2 = sport, 3 = sport plus
volatile float lat_Accel;
volatile float long_Accel;
volatile int throttle_Pos;
volatile float steering_Angle;
volatile float steering_Angle_Rate;
volatile float FL_Speed;
volatile float FR_Speed;
volatile float RL_Speed;
volatile float RR_Speed;
volatile int brake_Status;

// Read and convert CAN data
void ReadFrame(const CAN_message_t & frame){
  uint32_t id = frame.id;

  if (id == 0x22B){ 
    // Vehicle Mode
    switch (frame.buf[4]){
      case 0x10:
        Serial.println("Comfort");
        mode = 1;
        break;
      case 0x20:
        Serial.println("Sport");
        mode = 2;
        break;
      case 0x30:
        Serial.println("Sprot +");
        mode = 3;
        break;
      default: 
        Serial.println("error");
        mode = 0;

    }
  }

  else if (id == 0x094){

    // Lateral Acceleration [-20,20] m/s2
    uint16_t combined_lat = (frame.buf[0] << 8) | frame.buf[1];
    uint16_t raw_lat_Accel = (combined_lat >> 6) & 0x03FF;  
    lat_Accel = -0.035 * raw_lat_Accel + 17.92;

    // Longitudinal Acceleration [-20,20] m/s2
    uint16_t combined_long = (frame.buf[3] << 8) | frame.buf[4];
    uint16_t raw_long_Accel = combined_long & 0x03FF;  
    long_Accel = -0.035 * raw_long_Accel + 17.92;
  }

  else if (id == 0x17C){
    // Throttle Pedal Position [0,255]
    uint8_t raw_Pedal_Position = frame.buf[0] & 0xFF;
    throttle_Pos = raw_Pedal_Position;

    uint8_t raw_Brake_Status = (frame.buf[6] >> 5) & 0x01;
    brake_Status = raw_Brake_Status;
  }

  else if (id == 0x14A){
    // Steering Angle [-500,500] deg
    int16_t raw_Signed_Steer_Angle = (frame.buf[5] << 8) | frame.buf[6];
    steering_Angle = -0.1 * raw_Signed_Steer_Angle;

    //Steering Angle Rate [-3000,3000] deg/s
    int16_t raw_Signed_Steer_Angle_Rate = (frame.buf[2] << 8) | frame.buf[3];
    steering_Angle_Rate = -1 * raw_Signed_Steer_Angle_Rate;
  }

  else if (id == 0x1D0){
    // Wheel speeds Front Left [0,250] (kph)
    uint16_t combined_FL_Speed = (frame.buf[0] << 8) | frame.buf[1];
    uint16_t raw_FL_Speed = (combined_FL_Speed >> 1) & 0x7FFF;
    FL_Speed = 0.01 * raw_FL_Speed;

    // Wheel speeds Front Right [0,250] (kph)
    uint32_t combined_FR_Speed1 = (frame.buf[1] << 8) | frame.buf[2];
    uint32_t combined_FR_Speed2 = (combined_FR_Speed1 << 8) | frame.buf[3];
    uint32_t raw_FR_Speed = (combined_FR_Speed2 >> 2) & 0x00007FFF;
    FR_Speed = 0.01 * raw_FR_Speed;

    // Wheel speeds Rear Left [0,250] (kph)
    uint32_t combined_RL_Speed1 = (frame.buf[3] << 8) | frame.buf[4];
    uint32_t combined_RL_Speed2 = (combined_RL_Speed1 << 8) | frame.buf[5];
    uint32_t raw_RL_Speed = (combined_RL_Speed2 >> 3) & 0x00007FFF;
    RL_Speed = 0.01 * raw_RL_Speed;

    // Wheel speeds Rear Right [0,250] (kph)
    uint32_t combined_RR_Speed1 = (frame.buf[5] << 8) | frame.buf[6];
    uint32_t combined_RR_Speed2 = (combined_RR_Speed1 << 8) | frame.buf[7];
    uint32_t raw_RR_Speed = (combined_RR_Speed2 >> 4) & 0x00007FFF;
    RR_Speed = 0.01 * raw_RR_Speed;
  }
}

// Initialize datalog 
void InitSD() {
  if (!SD.begin(chipSelect)) {
    Serial.println("SD init failed!");
    while (1);
  }
  Serial.println("SD init success");

  int fileIndex = 0;
  String filename;

  while (true) {
    filename = "data" + String(fileIndex) + ".csv";
    if (!SD.exists(filename.c_str())) break;
    fileIndex++;
  }

  logFile = SD.open(filename.c_str(), FILE_WRITE);

  if (logFile) {
    Serial.println("File opened");

    // CSV header
    logFile.println("time,mode,lat,long,throttle,brake,steer,steer_rate,FL_WSpeed,FR_WSpeed,RL_WSpeed,RR_WSpeed,RL_Stroke,RR_Stroke,FL_Stroke,FR_Stroke,RL_Cur,RR_Cur,FL_Cur,FR_Cur,RL_Accel,RR_Accel,FL_Accel,FL_PWM");
    logFile.flush();
  } else {
    Serial.println("Error opening file!");
  }
}

// Log Data
void LogData() {
  if (!logFile) return;

  logFile.print(millis());
  logFile.print(",");

  logFile.print(mode); logFile.print(",");
  logFile.print(lat_Accel); logFile.print(",");
  logFile.print(long_Accel); logFile.print(",");
  logFile.print(throttle_Pos); logFile.print(",");
  logFile.print(brake_Status); logFile.print(",");
  logFile.print(steering_Angle); logFile.print(",");
  logFile.print(steering_Angle_Rate); logFile.print(",");
  logFile.print(FL_Speed); logFile.print(",");
  logFile.print(FR_Speed); logFile.print(",");
  logFile.print(RL_Speed); logFile.print(",");
  logFile.print(RR_Speed); logFile.print(",");

  // ADC values 
  for (int i = 0; i < 11; i++) {
    logFile.print(adcValues[i]);
    logFile.print(",");
  }

  logFile.print(GetPWMDuty());

  logFile.println();

  // Flush occasionally (not every write)
  static int counter = 0;
  counter++;
  if (counter >= 50) { // every 50 logs
    logFile.flush();
    counter = 0;
  }
}

void PrintData() {
  Serial.print("Time: "); Serial.print(millis()); Serial.println(" ms");

  Serial.print("Mode: "); Serial.println(mode);

  Serial.print("Lat Accel: "); Serial.print(lat_Accel, 3); Serial.println(" m/s^2");
  Serial.print("Long Accel: "); Serial.print(long_Accel, 3); Serial.println(" m/s^2");

  Serial.print("Throttle: "); Serial.print(throttle_Pos); Serial.println(" %");
  Serial.print("Brake: "); Serial.println(brake_Status);

  Serial.print("Steering Angle: "); Serial.print(steering_Angle, 2); Serial.println(" deg");
  Serial.print("Steering Rate: "); Serial.print(steering_Angle_Rate, 2); Serial.println(" deg/s");

  Serial.print("Wheel Speeds (kph): ");
  Serial.print("FL="); Serial.print(FL_Speed, 2); Serial.print(" | ");
  Serial.print("FR="); Serial.print(FR_Speed, 2); Serial.print(" | ");
  Serial.print("RL="); Serial.print(RL_Speed, 2); Serial.print(" | ");
  Serial.print("RR="); Serial.print(RR_Speed, 2); Serial.println();

  // --- Suspension Stroke ---
  Serial.print("Stroke (mm): ");
  Serial.print("FL="); Serial.print(adcValues[2]); Serial.print(" | ");
  Serial.print("FR="); Serial.print(adcValues[3]); Serial.print(" | ");
  Serial.print("RL="); Serial.print(adcValues[0]); Serial.print(" | ");
  Serial.print("RR="); Serial.print(adcValues[1]); Serial.println();

  // --- Current ---
  Serial.print("Coil Current (A): ");
  Serial.print("FL="); Serial.print(adcValues[6]); Serial.print(" | ");
  Serial.print("FR="); Serial.print(adcValues[7]); Serial.print(" | ");
  Serial.print("RL="); Serial.print(adcValues[4]); Serial.print(" | ");
  Serial.print("RR="); Serial.print(adcValues[5]); Serial.println();

  // --- Acceleration ---
  Serial.print("Susp Accel (m/s^2): ");
  Serial.print("FL="); Serial.print(adcValues[10]); Serial.print(" | ");
  Serial.print("RL="); Serial.print(adcValues[8]); Serial.print(" | ");
  Serial.print("RR="); Serial.print(adcValues[9]); Serial.println();

  // --- PWM ---
  Serial.print("PWM Output: ");
  Serial.print("FR="); Serial.print(GetPWMDuty(), 1); Serial.print(" %");

  Serial.println();

  Serial.println("--------------------------------------------------");
}

float GetPWMDuty() {
  noInterrupts();
  uint32_t w = width;
  uint32_t p = period;
  uint32_t last = lastEdgeTime;
  interrupts();

  // No signal yet
  if (p == 0) return 0;

  // Detect 100% (no falling edge for a while)
  if ((micros() - last) > 2000) { // >1 period (2kHz = 500µs)
    if (digitalRead(40)) return 100.0;
    else return 0.0;
  }

  float duty = (w * 100.0) / p;

  // Clamp to clean values
  if (duty > 100) duty = 100;
  if (duty < 0) duty = 0;

  return duty;
}


// Main setup code

void setup() {

  Serial.begin(115200); 
  myTimer.begin(AdcISR, samplingRate); //start ADC reading according to sampling rate
  SetupPWM(); // set PWM pinout and frequency
  InitCan();
  InitSD();
  pinMode(40, INPUT);
  attachInterrupt(digitalPinToInterrupt(40), pwmISR, CHANGE);
}

void loop() {
  Can0.events();
  if (logTimer >= logInterval) {
    logTimer = 0;
    LogData();
  }
  if (serialTimer >= 200) { // 5 Hz 
    serialTimer = 0;
    PrintData();
  }

}
