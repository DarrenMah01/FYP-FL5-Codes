#include <FlexCAN_T4.h>
#include <SD.h>
#include <math.h>
#include <stdio.h>



// Define your ADC pins
const int adcPins[] = {A0,A1,A2,A3,A4,A5,A6,A7,A8,A9,A17,A16};
const int numChannels = sizeof(adcPins) / sizeof(adcPins[0]);
int adcValues[numChannels];
const int samplingRate = 1000; //in microsecond = 1kHz
IntervalTimer myTimer;

// Define PWM Outputs
const int pwmPins[] = {2,3,4,5};
const int pwmFreq = 1000;

// Define CAN setups
FlexCAN_T4<CAN3, RX_SIZE_256, TX_SIZE_16> Can0; // using CAN Controller No.3 
const int CANBaud = 500000; //CAN Speed

// Interrupt routine for ADC reading
void AdcISR() {
  for (int i = 0; i < numChannels; i++){
    adcValues[i] = analogRead(adcPins[i]);
  }
}

// Convert ADC value into 0 - 5V value
float Convert2Volt(int inVal) {
  return ((float(inVal) * 5) /1023);
}

// Setup PWM pins 
void SetupPWM(){
  for (int i = 0; i < (sizeof(pwmPins)/sizeof(pwmPins[0])); i++){
    pinMode(pwmPins[i], OUTPUT); // set output pins
    analogWriteFrequency(pwmPins[i], pwmFreq);
  }
  analogWriteResolution(8);         // 8-bit resolution (0–255)
}

// Setup CAN Bus
void InitCan(){
  Can0.begin();
  Can0.setBaudRate(CANBaud);
  Can0.enableFIFO();
  Can0.enableFIFOInterrupt();
  Can0.onReceive(ReadFrame);
}
// CAN variables
volatile int mode = 0; //1 = comfort, 2 = sport, 3 = sport plus
volatile float lat_Accel;
volatile float long_Accel;
volatile int throttle_Pos;
volatile float steering_Angle;
volatile float steering_Angle_Rate;
volatile float FL_Speed;
volatile float FR_Speed;
volatile float RL_Speed;
volatile float RR_Speed;
volatile int brake_Status;

// Read and convert CAN data
void ReadFrame(const CAN_message_t & frame){
  uint32_t id = frame.id;

  if (id == 0x22B){ 
    // Vehicle Mode
    switch (frame.buf[4]){
      case 0x10:
        Serial.println("Comfort");
        mode = 1;
        break;
      case 0x20:
        Serial.println("Sport");
        mode = 2;
        break;
      case 0x30:
        Serial.println("Sprot +");
        mode = 3;
        break;
      default: 
        Serial.println("error");
        mode = 0;

    }
  }

  else if (id == 0x094){

    // Lateral Acceleration [-20,20] m/s2
    uint16_t combined_lat = (frame.buf[0] << 8) | frame.buf[1];
    uint16_t raw_lat_Accel = (combined_lat >> 6) & 0x03FF;  
    lat_Accel = -0.035 * raw_lat_Accel + 17.92;

    // Longitudinal Acceleration [-20,20] m/s2
    uint16_t combined_long = (frame.buf[3] << 8) | frame.buf[4];
    uint16_t raw_long_Accel = combined_long & 0x03FF;  
    long_Accel = -0.035 * raw_long_Accel + 17.92;
  }

  else if (id == 0x17C){
    // Throttle Pedal Position [0,255]
    uint8_t raw_Pedal_Position = frame.buf[0] & 0xFF;
    throttle_Pos = raw_Pedal_Position;

    uint8_t raw_Brake_Status = (frame.buf[6] >> 5) & 0x01;
    brake_Status = raw_Brake_Status;
  }

  else if (id == 0x14A){
    // Steering Angle [-500,500] deg
    int16_t raw_Signed_Steer_Angle = (frame.buf[5] << 8) | frame.buf[6];
    steering_Angle = -0.1 * raw_Signed_Steer_Angle;

    //Steering Angle Rate [-3000,3000] deg/s
    int16_t raw_Signed_Steer_Angle_Rate = (frame.buf[2] << 8) | frame.buf[3];
    steering_Angle_Rate = -1 * raw_Signed_Steer_Angle_Rate;
  }

  else if (id == 0x1D0){
    // Wheel speeds Front Left [0,250] (kph)
    uint16_t combined_FL_Speed = (frame.buf[0] << 8) | frame.buf[1];
    uint16_t raw_FL_Speed = (combined_FL_Speed >> 1) & 0x7FFF;
    FL_Speed = 0.01 * raw_FL_Speed;

    // Wheel speeds Front Right [0,250] (kph)
    uint32_t combined_FR_Speed1 = (frame.buf[1] << 8) | frame.buf[2];
    uint32_t combined_FR_Speed2 = (combined_FR_Speed1 << 8) | frame.buf[3];
    uint32_t raw_FR_Speed = (combined_FR_Speed2 >> 2) & 0x00007FFF;
    FR_Speed = 0.01 * raw_FR_Speed;

    // Wheel speeds Rear Left [0,250] (kph)
    uint32_t combined_RL_Speed1 = (frame.buf[3] << 8) | frame.buf[4];
    uint32_t combined_RL_Speed2 = (combined_RL_Speed1 << 8) | frame.buf[5];
    uint32_t raw_RL_Speed = (combined_RL_Speed2 >> 3) & 0x00007FFF;
    RL_Speed = 0.01 * raw_RL_Speed;

    // Wheel speeds Rear Right [0,250] (kph)
    uint32_t combined_RR_Speed1 = (frame.buf[5] << 8) | frame.buf[6];
    uint32_t combined_RR_Speed2 = (combined_RR_Speed1 << 8) | frame.buf[7];
    uint32_t raw_RR_Speed = (combined_RR_Speed2 >> 4) & 0x00007FFF;
    RR_Speed = 0.01 * raw_RR_Speed;
  }
}

// Main setup code

void setup() {

  Serial.begin(115200); 
  myTimer.begin(AdcISR, samplingRate); //start ADC reading according to sampling rate
  SetupPWM(); // set PWM pinout and frequency
  InitCan();

}

void loop() {
  Can0.events()
  // put your main code here, to run repeatedly:

}
